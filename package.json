{
  "name": "palmeras-gym-app",
  "version": "1.0.0",
  "description": "Palmeras Gym - Sistema de Gestión de Gimnasio",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed.js",
    "electron": "electron .",
    "build": "electron-builder --win --x64",
    "dist": "electron-builder --win --x64 --publish never"
  },
  "build": {
    "appId": "com.palmerasgym.app",
    "productName": "Palmeras Gym",
    "directories": {
      "output": "build"
    },
    "files": [
      "electron/**/*",
      "server.js",
      "database.js",
      "ghsync.js",
      "index.html",
      "Movil/**/*",
      "package.json",
      ".ghsync.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Palmeras Gym",
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico",
      "installerHeaderIcon": "electron/icon.ico"
    }
  },
  "dependencies": {
    "@electron/get": "^5.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "multer": "^2.1.1",
    "sql.js": "^1.11.0"
  },
  "nodemonConfig": {
    "ignore": [
      "backups/*.db",
      "*.db",
      "node_modules/"
    ]
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.0",
    "nodemon": "^3.1.14",
    "sharp": "^0.35.2"
  }
}
